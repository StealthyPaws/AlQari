<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:paddingHorizontal="16dp">

    <!-- Top Bar Include -->
    <include
        android:id="@+id/include_topBar"
        layout="@layout/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ScrollView for proper scrolling above nav bar -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/include_topBar"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ٱلْجَوْف -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlJawf"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="ٱلْجَوْف"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/indopak"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_duo_button_blue"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginVertical="8dp" />

            <!-- ٱلْحَلْق -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlHalq"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="ٱلْحَلْق"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/indopak"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_duo_button_green"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginVertical="8dp" />

            <!-- ٱللِّسَان -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlLisan"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="ٱللِّسَان"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/indopak"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_duo_button_pink"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginVertical="8dp" />

            <!-- ٱلشَّفَتَان -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAshShafatan"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="ٱلشَّفَتَان"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/indopak"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_duo_button_lavender"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginVertical="8dp" />

            <!-- ٱلْخَيْشُوم -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlKhayshum"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="ٱلْخَيْشُوم"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/indopak"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_duo_button_blue"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginVertical="8dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Bar Include -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
