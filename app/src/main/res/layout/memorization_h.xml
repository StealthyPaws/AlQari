<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Heading with Background Image -->
    <FrameLayout
        android:id="@+id/headingContainer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/headingBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/header" />

        <TextView
            android:id="@+id/surahName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سورة"
            android:textSize="26sp"
            android:textColor="@android:color/white"
            android:textDirection="rtl"
            android:layout_gravity="center"/>

    </FrameLayout>

    <!-- Main Image where Ayahs will be displayed -->

    <ScrollView
        android:id="@+id/hScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headingContainer"
        app:layout_constraintBottom_toTopOf="@id/Tab"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/hAyahContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"/>
    </ScrollView>



    <!-- Tab (above Bottom Bar) -->
    <LinearLayout
        android:id="@+id/Tab"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_duo_button_pink"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="6dp"
        android:elevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Button: Play All -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center">

            <ImageButton
                android:id="@+id/btnPlayAll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_play_arrow"
                app:tint="@android:color/white"
                android:contentDescription="Play All" />
        </FrameLayout>

        <!-- Button: Microphone -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_gravity="center">

            <ImageButton
                android:id="@+id/btnMicrophone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/microphone"
                android:contentDescription="Microphone" />
        </FrameLayout>

        <!-- Button: Visibility Toggle -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_gravity="center">

            <ImageButton
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/visible"
                android:contentDescription="Toggle visibility" />
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom Bar -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
