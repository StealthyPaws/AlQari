<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_ayah_border">

    <!-- Ayah Number Box (e.g., 1:1) -->
    <TextView
        android:id="@+id/ayahNumberBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_duo_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="1:1"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:fontFamily="@font/nunito"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Play Button for Ayah -->
    <ImageButton
        android:id="@+id/btnPlayAyah"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play_arrow"
        app:tint="@android:color/white"
        android:scaleType="fitCenter"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/ayahNumberBox"
        app:layout_constraintTop_toTopOf="@id/ayahNumberBox"
        app:layout_constraintBottom_toBottomOf="@id/ayahNumberBox" />





    <!-- Ayah Text (Arabic) -->
    <TextView
        android:id="@+id/tvAyahArabic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Arabic Text Here"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textDirection="rtl"
        app:layout_constraintTop_toBottomOf="@id/ayahNumberBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
