<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        android:background="@drawable/gradient_background"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainContentLayout"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- 🟣 Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar"/>

            <!-- 🟣 Overview Image -->
            <LinearLayout
                android:id="@+id/overviewCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:background="@drawable/bordered_card"
                android:clipToOutline="true"
                android:clickable="true"
                android:paddingHorizontal="3dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:id="@+id/overviewImage"
                    android:layout_width="180dp"
                    android:layout_height="175dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:contentDescription="Overview"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- 🟣 Description Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:text="General Overview"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/cardOverviewText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🟣 Buttons Layout -->
            <LinearLayout
                android:id="@+id/buttonLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="40dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNoon"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:layout_marginBottom="16dp"
                    android:text="ن"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/amiri"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    android:elevation="5dp"
                    app:cornerRadius="16dp"
                    app:icon="@null"
                    app:iconPadding="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMeem"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:text="م"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/amiri"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:background="@drawable/bg_duo_button_pink"
                    app:backgroundTint="@null"
                    android:elevation="5dp"
                    app:cornerRadius="16dp"
                    app:icon="@null"
                    app:iconPadding="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Popup Overlay -->
    <FrameLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <ImageView
            android:id="@+id/popupImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="Popup enlarged image" />
    </FrameLayout>

    <!-- 🟣 Bottom Bar Include -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
