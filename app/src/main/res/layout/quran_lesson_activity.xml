<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar" />

            <!-- Letter Glyph -->
            <TextView
                android:id="@+id/letterText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:paddingTop="8dp"
                android:textColor="#FFFFFF" />

            <!-- Letter Image (Hidden if none) -->
            <LinearLayout
                android:id="@+id/letterImageCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bordered_card"
                android:clipToOutline="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/letterImage"
                    android:layout_width="200dp"
                    android:layout_height="190dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:clickable="false"
                    android:focusable="false"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Makhrij Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/makhrajCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:id="@+id/makhrajTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Makhrij (Articulation Point)"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/makhrajBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Audio 1 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/audioBtn1"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_duo_button_blue"
                app:backgroundTint="@null"
                android:gravity="center"
                app:cornerRadius="16dp"
                app:icon="@drawable/audio"
                app:iconTint="@null"
                app:iconSize="32dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                android:visibility="gone" />

            <!-- How to Pronounce -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/pronounceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:id="@+id/pronounceTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How to Pronounce"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/pronounceBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Audio 2 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/audioBtn2"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_duo_button_blue"
                app:backgroundTint="@null"
                android:gravity="center"
                app:cornerRadius="16dp"
                app:icon="@drawable/audio"
                app:iconTint="@null"
                app:iconSize="32dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart"
                android:visibility="gone" />

            <!-- Practice Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/practiceBtn"
                android:layout_width="220dp"
                android:layout_height="56dp"
                android:text="Practice"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_duo_button_green"
                app:backgroundTint="@null"
                app:cornerRadius="16dp"
                android:layout_marginTop="20dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Popup Overlay -->
    <FrameLayout
        android:id="@+id/popupContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <ImageView
            android:id="@+id/popupImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="Popup enlarged image" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
