<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- 🔹 Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        android:background="@drawable/gradient_background"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- 🔹 Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar" />

            <!-- 🔹 Title Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/titleCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:text="Salah Guide"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Select a Surah and begin your Salah recording practice."
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🔹 Surah Selector -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">

                <!-- ✅ FIXED TextView (added width and height) -->
                <TextView
                    android:text="Choose a Surah"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_gravity="center" />

                <!-- 🔹 Dropdown Spinner -->
                <Spinner
                    android:id="@+id/spinnerSurahs"
                    android:layout_width="220dp"
                    android:layout_height="56dp"
                    android:popupBackground="@drawable/bg_spinner_popup"
                    android:background="@drawable/bg_duo_card"
                    android:spinnerMode="dropdown"
                    android:layout_marginBottom="20dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecord"
                    android:layout_width="200dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Record"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_duo_button_pink"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <!-- 🔹 View Logs Label -->
            <TextView
                android:text="View Logs"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- 🔹 Salah Buttons -->
            <GridLayout
                android:id="@+id/gridSalahButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFajr"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Fajr"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDhuhr"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Dhuhr"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
 />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAsr"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Asr"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
 />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMaghrib"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Maghrib"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
 />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEisha"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:text="Eisha"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
 />
            </GridLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🔹 Bottom Navigation -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
