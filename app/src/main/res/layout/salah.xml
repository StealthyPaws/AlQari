<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- 🔹 Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- 🔹 Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar" />


            <!-- 🔹 Buttons Layout -->
            <LinearLayout
                android:id="@+id/buttonLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp">

                <!-- 🟣 Memorize Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMemorize"
                    android:layout_width="220dp"
                    android:layout_height="56dp"
                    android:text="Memorize"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    android:layout_marginBottom="20dp"/>

                <!-- 🟣 Log Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLog"
                    android:layout_width="220dp"
                    android:layout_height="56dp"
                    android:text="Log"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_duo_button_pink"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"

                    android:layout_marginBottom="20dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🔹 Bottom Navigation -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
