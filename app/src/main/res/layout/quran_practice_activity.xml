<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:id="@+id/scrollViewPractice"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar" />

            <!-- The Letter -->
            <TextView
                android:id="@+id/practiceLetter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="?"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingTop="12dp" />

            <!-- Instructions -->
            <TextView
                android:id="@+id/practiceInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap the button below and pronounce the letter."
                android:textColor="#EDEBFF"
                android:textSize="16sp"
                android:fontFamily="@font/nunito"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="16dp" />

            <!-- Record Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="@font/nunito"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_duo_button_pink"
                app:backgroundTint="@null"
                app:cornerRadius="40dp"
                app:icon="@drawable/microphone_2"
                app:iconTint="@null"
                app:iconSize="32dp"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />

            <!-- Result Box -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:id="@+id/practiceResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#EDEBFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito"
                        android:text="Result will appear here..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
