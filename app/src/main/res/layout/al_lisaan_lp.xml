<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        android:background="@drawable/gradient_background"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar"/>

            <!-- Final balanced Overview Image border -->
            <LinearLayout
                android:id="@+id/overviewCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:background="@drawable/bordered_card"
                android:clipToOutline="true"
                android:clickable="true"
                android:paddingHorizontal="3dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:id="@+id/overviewImage"
                    android:layout_width="180dp"
                    android:layout_height="175dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:contentDescription="Overview"
                    android:background="@android:color/transparent" />
            </LinearLayout>


            <!-- 🟣 CARD 1: General Overview -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                        android:background="@drawable/bg_duo_card">

                    <TextView
                        android:text="General Overview"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/cardOverviewText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Letters Buttons -->
            <LinearLayout
                android:id="@+id/buttonLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

