<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/include_bottomBar"
        android:background="@drawable/gradient_background"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <!-- Top Bar -->
            <include
                android:id="@+id/include_topBar"
                layout="@layout/layout_top_bar"/>

            <!-- Hidden overview card (auto-hidden in code) -->
            <LinearLayout
                android:id="@+id/overviewCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/overviewImage"
                    android:layout_width="200dp"
                    android:layout_height="190dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 🟣 Card 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:id="@+id/card1Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Overview"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/card1Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🟣 Card 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_duo_card">

                    <TextView
                        android:id="@+id/card2Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How the Madd Letters Function"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/card2Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#EDEBFF"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons -->
            <LinearLayout
                android:id="@+id/buttonLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAlif"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:layout_marginBottom="12dp"
                    android:text="ا"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/amiri"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:background="@drawable/bg_duo_button_blue"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    app:icon="@null"
                    app:iconPadding="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWaw"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:layout_marginBottom="12dp"
                    android:text="و"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/amiri"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:background="@drawable/bg_duo_button_pink"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    app:icon="@null"
                    app:iconPadding="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnYa"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:layout_marginBottom="12dp"
                    android:text="ي"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/amiri"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:background="@drawable/bg_duo_button_green"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    app:icon="@null"
                    app:iconPadding="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/include_bottomBar"
        layout="@layout/layout_buttons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
